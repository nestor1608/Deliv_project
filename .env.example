# Copy this file to .env and adjust values for your environment.
# NEVER commit .env to version control.

# === Django Core ===
DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# === Database ===
# Set USE_POSTGRESQL=True to use PostgreSQL (requires Docker services running)
USE_POSTGRESQL=False
DB_NAME=deliv_db
DB_USER=deliv_user
DB_PASSWORD=deliv_pass_segura
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600
DB_CONNECT_TIMEOUT=10

# === Redis (cache, channels, celery broker) ===
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === Email ===
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@deliv.app
FRONTEND_URL=http://localhost:3000

# === Firebase / FCM ===
FCM_SERVER_KEY=your-fcm-server-key
FCM_SENDER_ID=firebase-adminsdk...

# === MercadoPago ===
MP_ACCESS_TOKEN=your-mp-access-token
MP_PUBLIC_KEY=your-mp-public-key
MP_WEBHOOK_SECRET=your-webhook-secret

# === Stripe ===
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# === Sentry (error tracking) ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# === CORS ===
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081
