components:
  schemas:
    AvailabilityEnum:
      enum:
      - available
      - busy
      - offline
      type: string
      description: |-
        * `available` - Disponible
        * `busy` - Ocupado
        * `offline` - Desconectado
    BulkNotificationRequest:
      type: object
      description: Serializer para notificaciones masivas
      properties:
        title:
          type: string
          minLength: 1
          maxLength: 200
        body:
          type: string
          minLength: 1
        user_roles:
          type: array
          items:
            $ref: '#/components/schemas/UserRolesEnum'
        user_ids:
          type: array
          items:
            type: integer
        data: {}
      required:
      - body
      - title
    ChangePassword:
      type: object
      properties:
        old_password:
          type: string
        new_password:
          type: string
          minLength: 8
      required:
      - new_password
      - old_password
    ChangePasswordRequest:
      type: object
      properties:
        old_password:
          type: string
          minLength: 1
        new_password:
          type: string
          minLength: 8
      required:
      - new_password
      - old_password
    CreateOrderRequest:
      type: object
      description: Serializer para crear nuevos pedidos
      properties:
        vendor:
          type: integer
        delivery_address:
