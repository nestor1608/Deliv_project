openapi: 3.0.3
info:
  title: Deliv API
  version: 1.0.0
  description: API de la plataforma híbrida de delivery y movilidad
paths:
  /api/auth/change-password/:
    put:
      operationId: auth_change_password_update
      description: Vista mejorada para cambiar contraseña
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/ChangePasswordRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/ChangePasswordRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/ChangePasswordRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ChangePassword'
          description: ''
    patch:
      operationId: auth_change_password_partial_update
      description: Vista mejorada para cambiar contraseña
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedChangePasswordRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedChangePasswordRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedChangePasswordRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ChangePassword'
          description: ''
  /api/auth/logout/:
    post:
      operationId: auth_logout_create
      description: Vista mejorada para cerrar sesión con invalidación de tokens
      tags:
      - auth
      security:
      - jwtAuth: []
      responses:
        '200':
          description: No response body
  /api/auth/password-reset/:
    post:
      operationId: auth_password_reset_create
      description: Envía un email con un enlace para restablecer la contraseña. Incluye
        rate limiting por email (5 minutos entre solicitudes). Por seguridad, siempre
        retorna el mismo mensaje independientemente de si el email existe.
      summary: Solicitar restablecimiento de contraseña
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PasswordResetRequestRequest'
            examples:
              SolicitudDeRecuperación:
                value:
                  email: usuario@ejemplo.com
                summary: Ejemplo de solicitud
                description: Ejemplo de una solicitud de restablecimiento de contraseña
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PasswordResetRequestRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PasswordResetRequestRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: Mensaje genérico indicando que si el email existe, se enviará
            el enlace de recuperación
        '429':
          description: Demasiadas solicitudes - ya se envió un enlace recientemente.
            Espera 5 minutos.
  /api/auth/password-reset-confirm/{uidb64}/{token}/:
    post:
      operationId: auth_password_reset_confirm_create
      description: Confirma el restablecimiento de contraseña usando el UID y token
        enviados por email. Valida que el enlace sea válido y no haya expirado.
      summary: Confirmar restablecimiento de contraseña
      parameters:
      - in: path
        name: token
        schema:
          type: string
        required: true
      - in: path
        name: uidb64
        schema:
          type: string
        required: true
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PasswordResetConfirmRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PasswordResetConfirmRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PasswordResetConfirmRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '200':
          description: Contraseña restablecida correctamente
        '400':
          description: Enlace inválido o expirado - el UID o token no son válidos
  /api/auth/profile/:
    get:
      operationId: auth_profile_retrieve
      description: Retorna los datos del perfil del usuario autenticado.
      summary: Obtener perfil de usuario
      tags:
      - auth
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/User'
          description: ''
    put:
      operationId: auth_profile_update
      description: Actualiza todos los datos del perfil del usuario autenticado. No
        permite modificar campos críticos como username, role o status.
      summary: Actualizar perfil de usuario (completo)
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/UserRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/UserRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/UserRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/User'
          description: ''
        '400':
          description: Error de validación o campo restringido
    patch:
      operationId: auth_profile_partial_update
      description: Actualiza parcialmente los datos del perfil del usuario autenticado.
        No permite modificar campos críticos como username, role o status.
      summary: Actualizar perfil de usuario (parcial)
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedUserRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedUserRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedUserRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/User'
          description: ''
        '400':
          description: Error de validación o campo restringido
  /api/auth/register/:
    post:
      operationId: auth_register_create
      description: Vista para registro de nuevos usuarios con validaciones mejoradas
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/UserRegistrationRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/UserRegistrationRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/UserRegistrationRequest'
        required: true
      security:
      - jwtAuth: []
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/UserRegistration'
          description: ''
  /api/auth/token/:
    post:
      operationId: auth_token_create
      description: Autentica un usuario usando nombre de usuario o email y contraseña.
        Retorna tokens JWT (access y refresh) junto con los datos del usuario. Valida
        el rol del usuario para control de acceso.
      summary: Inicio de sesión
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/LoginRequest'
            examples:
              LoginExitoso:
                value:
                  username_or_email: usuario@ejemplo.com
                  password: contraseña123
                  user_type: customer
                summary: Ejemplo de inicio de sesión
                description: Ejemplo de una solicitud de inicio de sesión exitosa
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/LoginRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/LoginRequest'
        required: true
      responses:
        '200':
          description: Autenticación exitosa - retorna tokens JWT y datos del usuario
        '400':
          description: Error de autenticación - credenciales inválidas, cuenta inactiva
            o rol incorrecto
  /api/auth/token/refresh/:
    post:
      operationId: auth_token_refresh_create
      description: |-
        Takes a refresh type JSON web token and returns an access type JSON web
        token if the refresh token is valid.
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenRefreshRequest'
        required: true
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/TokenRefresh'
          description: ''
  /api/auth/token/verify/:
    post:
      operationId: auth_token_verify_create
      description: |-
        Takes a token and indicates if it is valid.  This view provides no
        information about a token's fitness for a particular use.
      tags:
      - auth
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TokenVerifyRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/TokenVerifyRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/TokenVerifyRequest'
        required: true
      responses:
        '200':
          description: No response body
  /api/customers/addresses/:
    get:
      operationId: customers_addresses_list
      description: Retorna la lista de direcciones guardadas del cliente autenticado.
      summary: Listar direcciones del cliente
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - customers
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedCustomerAddressList'
          description: ''
    post:
      operationId: customers_addresses_create
      description: Crea una nueva dirección para el cliente autenticado. Si se marca
        como predeterminada, las demás direcciones se desmarcan automáticamente.
      summary: Crear dirección del cliente
      tags:
      - customers
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CustomerAddressRequest'
            examples:
              NuevaDirección:
                value:
                  label: Casa
                  street_address: Av. Principal 123
                  city: Ciudad de México
                  state: CDMX
                  postal_code: '06600'
                  country: México
                  is_default: true
                summary: Ejemplo de creación de dirección
                description: Ejemplo de una solicitud para crear una nueva dirección
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CustomerAddressRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CustomerAddressRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CustomerAddress'
          description: ''
        '400':
          description: Error de validación
  /api/customers/addresses/{id}/:
    get:
      operationId: customers_addresses_retrieve
      description: Retorna los detalles de una dirección específica del cliente autenticado.
      summary: Obtener dirección del cliente
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      tags:
      - customers
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CustomerAddress'
          description: ''
    put:
      operationId: customers_addresses_update
      description: Actualiza todos los campos de una dirección específica del cliente
        autenticado.
      summary: Actualizar dirección (completa)
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      tags:
      - customers
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CustomerAddressRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CustomerAddressRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CustomerAddressRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CustomerAddress'
          description: ''
    patch:
      operationId: customers_addresses_partial_update
      description: Actualiza parcialmente los campos de una dirección específica del
        cliente autenticado.
      summary: Actualizar dirección (parcial)
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      tags:
      - customers
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedCustomerAddressRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedCustomerAddressRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedCustomerAddressRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CustomerAddress'
          description: ''
    delete:
      operationId: customers_addresses_destroy
      description: Elimina una dirección específica del cliente autenticado.
      summary: Eliminar dirección
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        required: true
      tags:
      - customers
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/customers/profile/:
    get:
      operationId: customers_profile_retrieve
      description: Retorna los datos del perfil de cliente del usuario autenticado.
        Si no existe un perfil de cliente, lo crea automáticamente.
      summary: Obtener perfil de cliente
      tags:
      - customers
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Customer'
          description: ''
    put:
      operationId: customers_profile_update
      description: Actualiza todos los datos del perfil de cliente del usuario autenticado.
      summary: Actualizar perfil de cliente (completo)
      tags:
      - customers
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CustomerRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/CustomerRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/CustomerRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Customer'
          description: ''
    patch:
      operationId: customers_profile_partial_update
      description: Actualiza parcialmente los datos del perfil de cliente del usuario
        autenticado.
      summary: Actualizar perfil de cliente (parcial)
      tags:
      - customers
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedCustomerRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedCustomerRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedCustomerRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/Customer'
          description: ''
  /api/delivery/delivery-persons/:
    get:
      operationId: delivery_delivery_persons_list
      description: Obtiene la lista de repartidores según el perfil del usuario.
      summary: Listar repartidores
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - delivery
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedDeliveryPersonList'
          description: ''
    post:
      operationId: delivery_delivery_persons_create
      description: Registra un nuevo repartidor en el sistema.
      summary: Crear repartidor
      tags:
      - delivery
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/DeliveryPersonRegistrationRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/DeliveryPersonRegistrationRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/DeliveryPersonRegistrationRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DeliveryPersonRegistration'
          description: ''
  /api/delivery/delivery-persons/{id}/:
    get:
      operationId: delivery_delivery_persons_retrieve
      description: Obtiene los detalles de un repartidor específico.
      summary: Obtener repartidor
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this delivery person.
        required: true
      tags:
      - delivery
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DeliveryPerson'
          description: ''
    put:
      operationId: delivery_delivery_persons_update
      description: Actualiza los datos completos de un repartidor.
      summary: Actualizar repartidor
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this delivery person.
        required: true
      tags:
      - delivery
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/DeliveryPersonRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/DeliveryPersonRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/DeliveryPersonRequest'
        required: true
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DeliveryPerson'
          description: ''
    patch:
      operationId: delivery_delivery_persons_partial_update
      description: Actualiza parcialmente los datos de un repartidor.
      summary: Actualizar parcialmente repartidor
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this delivery person.
        required: true
      tags:
      - delivery
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedDeliveryPersonRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedDeliveryPersonRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedDeliveryPersonRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DeliveryPerson'
          description: ''
    delete:
      operationId: delivery_delivery_persons_destroy
      description: ViewSet para repartidores
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this delivery person.
        required: true
      tags:
      - delivery
      security:
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /api/delivery/delivery-persons/{id}/active_orders/:
    get:
      operationId: delivery_delivery_persons_active_orders_list
      description: Obtiene los pedidos activos asignados al repartidor.
      summary: Pedidos activos
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this delivery person.
        required: true
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
          type: string
      tags:
      - delivery
      security:
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedOrderList'
          description: ''
  /api/delivery/delivery-persons/{id}/earnings/:
    get:
      operationId: delivery_delivery_persons_earnings_retrieve
      description: Obtiene las ganancias totales del repartidor con filtros opcionales
        por fecha.
      summary: Ganancias del repartidor
      parameters:
      - in: query
        name: from_date
        schema:
          type: string
          format: date
        description: Fecha inicial (YYYY-MM-DD)
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this delivery person.
        required: true
      - in: query
        name: to_date
        schema:
          type: string
          format: date
        description: Fecha final (YYYY-MM-DD)
      tags:
      - delivery
      security:
      - jwtAuth: []
      responses:
        '200':
          description: Ganancias del repartidor
  /api/delivery/delivery-persons/{id}/update_availability/:
    patch:
      operationId: delivery_delivery_persons_update_availability_partial_update
      description: Cambia la disponibilidad actual del repartidor.
      summary: Cambiar disponibilidad
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this delivery person.
        required: true
      tags:
      - delivery
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedDeliveryAvailabilityRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedDeliveryAvailabilityRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedDeliveryAvailabilityRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          description: Disponibilidad actualizada
  /api/delivery/delivery-persons/{id}/update_location/:
    patch:
      operationId: delivery_delivery_persons_update_location_partial_update
      description: Actualiza la ubicación geográfica del repartidor.
      summary: Actualizar ubicación
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this delivery person.
        required: true
      tags:
      - delivery
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedDeliveryLocationUpdateRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedDeliveryLocationUpdateRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedDeliveryLocationUpdateRequest'
      security:
      - jwtAuth: []
      responses:
        '200':
          description: Ubicación actualizada correctamente
  /api/delivery/ratings/:
    get:
      operationId: delivery_ratings_list
      description: Obtiene la lista de calificaciones de repartidores para el cliente
        autenticado.
      summary: Listar calificaciones
      parameters:
      - name: ordering
        required: false
        in: query
        description: Which field to use when ordering the results.
        schema:
          type: string
      - name: page
        required: false
        in: query
        description: A page number within the paginated result set.
        schema:
          type: integer
      - name: search
        required: false
        in: query
        description: A search term.
        schema:
